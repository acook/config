[user]
  name = Anthony Cook
  email = github@anthonymcook.com

[core]
  #pager = less -FRSX
  pager = delta
  whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore_global
  editor = nvim

[interactive]
  diffFilter = delta --color-only --features=interactive

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  pager = true

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta
  old = red
  new = green

[color "status"]
  added = green
  changed = yellow bold
  untracked = white

[alias]
  co = checkout
  st = status
  ci = commit
  w  = whatchanged
  nb = checkout -b
  b  = branch
  down = pull --rebase

  amend = commit --amend

  stashs  = stash --keep-index
  unstash = stash pop
  unstage = reset HEAD --

  branches = branch -v
  remotes = remote -v
  tags = tag -n -l
  origin = remote show origin

  dog = log --decorate --oneline --graph
  hist = log --graph  --abbrev-commit --date=relative --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'

  # show the message for the most recent commit, also shows if it is signed
  last = log --show-signature -1 HEAD
  # find parent of the given commit
  parent = log --pretty=%P -n 1
  # find all of the children for a given commit
  children = "!bash -c 'c=${1:-HEAD}; set -- $(git rev-list --all --not \"$c\"^@ --children | grep $(git rev-parse \"$c\") ); shift; echo $*' -"

  root = rev-parse --show-toplevel
  top = !eval cd "$(pwd)/$(git rev-parse --show-cdup)" && pwd

  ls = ls-tree HEAD --name-only
  unmerged = ls-files --unmerged

  subdo = submodule foreach git
  # show the total size of files
  stats = !git diff --stat `git hash-object -t tree /dev/null`

  diffs = diff --staged
  diffh = diff HEAD

  vimdiff = difftool --tool=vimdiff
  p4diff = difftool --tool=p4merge
  meld = difftool --tool=meld
  nvd = difftool --tool=nvimdiff
  komp = difftool --tool=kompare
  ddiff = difftool --tool=diffuse

  vimdiffs = vimdiff --staged
  p4diffs = p4diff --staged
  melds = meld --staged
  nvds = ndiff --staged
  komps = kdiff --staged
  ddiffs = ddiff --staged

  # show the oldest commit
  oldest = "!git log --follow --pretty=%H -- \"$*\" | tail -n 1 #"
  # show the date of the oldest commit
  oldestdate = "!git isodate $(git oldest \"$*\") #"

  # show the date of the current (or specified) commit
  isodate = show --format=%ad --date=format:'%Y-%m-%dT%H:%M:%S%z' --no-patch

[merge]
  default = current
  conflictstyle = diff3
  tool = nvimdiff
  guitool = meld

[mergetool]
  keepBackup = false
  prompt = false

[mergetool "p4merge"]
  cmd = p4merge "$PWD/$BASE" "$PWD/$LOCAL" "$PWD/$REMOTE" "$PWD/$MERGED"
  keepTemporaries = false
  trustExitCode = false
  keepBackup = false

[mergetool "meld"]
  cmd = meld "$LOCAL" "$MERGED" "$REMOTE" --output "$MERGED"

[mergetool "meldbase"]
  cmd = meld "$LOCAL" "$BASE" "$REMOTE" --output "$MERGED"

[diff]
  prompt = false
  colorMoved = default
  tool = meld

[difftool]
  prompt = false

[difftool "meld"]
  cmd = meld "$LOCAL" "$REMOTE"

[difftool "p4merge"]
  cmd = p4merge "$LOCAL" "$REMOTE"

[difftool "nvimdiff"]
  cmd = nvim -d "$LOCAL" "$REMOTE"

[delta]
  navigate = true
  features = decorations
  default-language = bash

[delta "interactive"]
  keep-plus-minus-markers = false

[delta "decorations"]
  syntax-theme = Monokai Extended Origin
  commit-decoration-style = blue ol
  commit-style = raw
  file-style = omit
  hunk-header-decoration-style = blue box
  hunk-header-file-style = red
  hunk-header-line-number-style = "#067a00"
  hunk-header-style = file line-number syntax
  line-numbers = true
  side-by-side = true

[init]
  defaultBranch = main

[checkout]
	defaultRemote = origin

[push]
  default = current

[pull]
  default = current

[branch "main"]
  remote = origin
  merge = refs/heads/main

[filter "media"]
  clean = git-media-clean %f
  smudge = git-media-smudge %f

[filter "lfs"]
  clean = git-lfs clean %f
  smudge = git-lfs smudge %f
  required = true

[gpg]
  program = gpg

[commit]
	gpgSign = true

[tag]
	forceSignAnnotated = true

[url "https://codeberg.org/"]
  insteadOf = "cb:"

[url "git@codeberg.org:"]
  pushInsteadOf = "https://codeberg.org/"
  pushInsteadOf = "http://codeberg.org/"
  pushInsteadOf = "cb:"

[url "https://github.com/"]
  insteadOf = "gh:"

[url "git@github.com:"]
  pushInsteadOf = "https://github.com/"
  pushInsteadOf = "http://github.com/"
  pushInsteadOf = "gh:"

[url "https://gist.github.com/"]
  insteadOf = "gist:"

[url "git@gist.github.com:"]
  pushInsteadOf = "https://gist.github.com/"
  pushInsteadOf = "http://gist.github.com/"
  pushInsteadOf = "gist:"

[include]
  path = ~/.gitconfig.local

[includeIf "gitdir/i:*Work*"]
  path = ~/.gitconfig.work

